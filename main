<body>
  <div class="app">
    <div class="hero">
      <h1>Tool Inventory Job Demo</h1>
      <p class="subtitle">Type a job name. If the required tools are available, they are removed from inventory.</p>
    </div>

    <div class="panel">
      <div class="job-box">
        <input id="jobInput" placeholder="Try: Job A, Job B, Job C" />
        <button onclick="runJob()">Run Job</button>
        <button class="reset" onclick="resetInventory()">Reset Demo</button>
      </div>
      <p id="status" class="status"></p>
      <p class="hint">Demo jobs: Job A, Job B, Job C, Job D</p>
    </div>

    <div class="grid">
      <div class="panel">
        <h2>Available Tool Inventory</h2>
        <div id="inventoryList"></div>
      </div>

      <div class="panel">
        <h2>Job Requirements</h2>
        <div id="jobList"></div>
      </div>
    </div>
  </div>

  <script>
    const startingInventory = {
      "Tool 1": 4,
      "Tool 2": 2,
      "Tool 3": 3,
      "Tool 4": 1,
      "Tool 5": 5
    };

    const jobs = {
      "job a": {
        displayName: "Job A",
        tools: {
          "Tool 1": 1,
          "Tool 2": 1
        }
      },
      "job b": {
        displayName: "Job B",
        tools: {
          "Tool 1": 2,
          "Tool 3": 1,
          "Tool 5": 2
        }
      },
      "job c": {
        displayName: "Job C",
        tools: {
          "Tool 2": 2,
          "Tool 4": 1
        }
      },
      "job d": {
        displayName: "Job D",
        tools: {
          "Tool 1": 3,
          "Tool 3": 3,
          "Tool 4": 1,
          "Tool 5": 1
        }
      }
    };

    let inventory = JSON.parse(localStorage.getItem("toolInventoryDemo")) || { ...startingInventory };

    function saveInventory() {
      localStorage.setItem("toolInventoryDemo", JSON.stringify(inventory));
    }

    function renderInventory() {
      const inventoryList = document.getElementById("inventoryList");
      inventoryList.innerHTML = "";

      Object.entries(inventory).forEach(([tool, quantity]) => {
        inventoryList.innerHTML += `
          <div class="tool-card">
            <div>
              <div class="tool-name">${tool}</div>
              <div class="muted">Available quantity</div>
            </div>
            <div class="qty">${quantity}</div>
          </div>
        `;
      });
    }

    function renderJobs() {
      const jobList = document.getElementById("jobList");
      jobList.innerHTML = "";

      Object.values(jobs).forEach(job => {
        const requirements = Object.entries(job.tools)
          .map(([tool, quantity]) => `${quantity} × ${tool}`)
          .join(", ");

        jobList.innerHTML += `
          <div class="job-card">
            <div>
              <div class="job-name">${job.displayName}</div>
              <div class="muted">Requires: ${requirements}</div>
            </div>
          </div>
        `;
      });
    }

    function runJob() {
      const input = document.getElementById("jobInput").value.trim().toLowerCase();
      const status = document.getElementById("status");

      if (!jobs[input]) {
        status.className = "status error";
        status.textContent = "Job not found. Try Job A, Job B, Job C, or Job D.";
        return;
      }

      const job = jobs[input];
      const missingTools = [];

      Object.entries(job.tools).forEach(([tool, needed]) => {
        const available = inventory[tool] || 0;

        if (available < needed) {
          missingTools.push(`${tool}: need ${needed}, only ${available} available`);
        }
      });

      if (missingTools.length > 0) {
        status.className = "status error";
        status.textContent = `${job.displayName} cannot be completed. Missing: ${missingTools.join("; ")}.`;
        return;
      }

      Object.entries(job.tools).forEach(([tool, needed]) => {
        inventory[tool] -= needed;
      });

      saveInventory();
      renderInventory();

      status.className = "status success";
      status.textContent = `${job.displayName} completed. Tools were removed from inventory.`;
      document.getElementById("jobInput").value = "";
    }

    function resetInventory() {
      inventory = { ...startingInventory };
      saveInventory();
      renderInventory();

      const status = document.getElementById("status");
      status.className = "status";
      status.textContent = "Inventory reset.";
    }

    renderInventory();
    renderJobs();
  </script>
</body>
</html>
